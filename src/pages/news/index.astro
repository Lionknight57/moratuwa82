---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const news = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="News — Moratuwa ’82">
  <h1>News</h1>
  <ul class="news-list">
    {news.map((item) => (
      <li>
        <a href={`/news/${item.slug}/`}>
          <span class="date">{fmt(item.data.date)}</span>
          <span class="title">{item.data.title}</span>
        </a>
        {item.data.summary && <p class="summary">{item.data.summary}</p>}
      </li>
    ))}
  </ul>

  <style>
    h1 { border-bottom: 1px solid var(--border); padding-bottom: 0.4rem; }
    .news-list { list-style: none; padding: 0; margin: 0; }
    .news-list li { padding: 1rem 0; border-bottom: 1px solid var(--border); }
    .news-list a { text-decoration: none; display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: baseline; }
    .news-list .date { color: var(--muted); font-size: 0.85rem; min-width: 8rem; }
    .news-list .title { color: var(--fg); font-weight: 600; font-size: 1.1rem; }
    .news-list .summary { color: var(--muted); margin: 0.35rem 0 0; }
  </style>
</BaseLayout>
