---
import BaseLayout from '../layouts/BaseLayout.astro';
import { disciplines, totalMembers, contactEmail } from '../data/members';
---

<BaseLayout
  title="Members — Moratuwa ’82"
  description="The batch member list, rebuilt from memory. Help us fill the gaps and fix the errors."
>
  <h1>Members</h1>

  <div class="notice">
    <p>
      <strong>This list is being rebuilt from memory.</strong> The old site kept our member
      list in a database that didn’t survive the move, so Kanishka is writing it out again
      from what he remembers — roughly three quarters of the batch. The rest, we need your
      help with.
    </p>
    <p class="ask">
      So please read your discipline below and tell us what’s wrong. Names spelled badly,
      someone under the wrong discipline, or missing altogether — all of it is likely, and
      none of it will offend anyone. Send corrections and the names we’ve forgotten to
      Kanishka at <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
    </p>
  </div>

  <p class="tally">
    {totalMembers === 0
      ? 'The names are going up now — check back shortly.'
      : `${totalMembers} names so far.`}
  </p>

  {disciplines.map((d) => (
    <section class="discipline">
      <div class="d-head">
        <h2>{d.label}</h2>
        <span class="count">{d.members.length === 0 ? 'awaiting names' : `${d.members.length} listed`}</span>
      </div>
      {d.members.length > 0 ? (
        <ul class="members">
          {d.members.map((m) => (
            <li>
              <span class="m-name">{m.name}</span>
              {m.note && <span class="m-note">{m.note}</span>}
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty">Not written up yet.</p>
      )}
    </section>
  ))}

  <style>
    h1 { border-bottom: 1px solid var(--border); padding-bottom: 0.4rem; }

    .notice {
      background: var(--card); border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 10px; padding: 1rem 1.15rem; margin: 1.5rem 0 2rem;
    }
    .notice p { margin: 0; }
    .notice .ask { margin-top: 0.75rem; color: var(--muted); }

    .tally { color: var(--muted); }

    .discipline { margin-top: 2rem; }
    .d-head {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 0.75rem; border-bottom: 1px solid var(--border); padding-bottom: 0.35rem;
    }
    .d-head h2 { font-size: 1.1rem; margin: 0; }
    .count { color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; }

    .members { list-style: none; padding: 0; margin: 0.75rem 0 0; }
    .members li { padding: 0.4rem 0; border-bottom: 1px solid var(--border); }
    .m-name { font-weight: 600; }
    .m-note { color: var(--muted); font-size: 0.9rem; margin-left: 0.5rem; }

    .empty { color: var(--muted); font-size: 0.9rem; margin: 0.75rem 0 0; }
  </style>
</BaseLayout>
