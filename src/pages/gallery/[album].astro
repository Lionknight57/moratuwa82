---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CldImage from '../../components/CldImage.astro';
import { cldUrl } from '../../lib/cloudinary';
import { albums } from '../../data/albums';
import type { Album } from '../../data/albums';

// One page per album at /gallery/<slug>, built from the registry.
export async function getStaticPaths() {
  return albums.map((album) => ({ params: { album: album.slug }, props: { album } }));
}

const { album } = Astro.props as { album: Album };

// Alt text: the caption's first line reads as a description; the rest is a
// name list that would be noise in a screen reader's image announcement.
const altFor = (caption: string, sectionTitle?: string) =>
  caption.split('\n')[0] || sectionTitle || album.title;
---

<BaseLayout title={`${album.title} — Moratuwa 77'-82'`} description={album.summary}>
  <p class="crumb"><a href="/gallery/">← Gallery</a></p>
  <h1>{album.title}</h1>
  {album.intro && <p class="intro">{album.intro}</p>}

  {album.sections.map((section) => (
    <section class="album-section">
      {section.title && <h2>{section.title}</h2>}
      <div class="grid">
        {section.photos.map((photo) => (
          <figure>
            <a
              class="ph-link"
              href={cldUrl(photo.publicId, { width: 1600, crop: 'fit' })}
              data-caption={photo.caption}
            >
              <CldImage
                publicId={photo.publicId}
                alt={altFor(photo.caption, section.title)}
                width={600}
                height={450}
                sizes="(max-width: 700px) 100vw, 300px"
              />
            </a>
            {photo.caption && <figcaption>{photo.caption}</figcaption>}
          </figure>
        ))}
      </div>
    </section>
  ))}

  {album.closing && <p class="closing">{album.closing}</p>}

  <!-- Lightbox: enhanced by the script below; falls back to opening the image. -->
  <div id="lightbox" class="lb" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <button class="lb-btn lb-close" type="button" aria-label="Close">&times;</button>
    <button class="lb-btn lb-prev" type="button" aria-label="Previous photo">&lsaquo;</button>
    <figure class="lb-stage">
      <div class="lb-imgwrap">
        <img class="lb-img" alt="" />
      </div>
      <figcaption class="lb-caption"></figcaption>
    </figure>
    <button class="lb-btn lb-next" type="button" aria-label="Next photo">&rsaquo;</button>
    <div class="lb-counter" aria-hidden="true"></div>
  </div>

  <style>
    h1 { border-bottom: 1px solid var(--border); padding-bottom: 0.4rem; }
    .crumb { margin: 0 0 0.5rem; font-size: 0.9rem; }
    .intro { color: var(--muted); }
    .album-section { margin-top: 2.5rem; }
    .album-section h2 { font-size: 1.05rem; color: var(--fg); margin: 0 0 0.75rem; }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
    }
    /* Scoped to .grid so these thumbnail rules never reach the lightbox figure. */
    .grid figure { margin: 0; background: var(--card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    .grid figure img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
    .ph-link { cursor: zoom-in; display: block; }
    .grid figcaption { padding: 0.6rem 0.75rem; color: var(--muted); font-size: 0.85rem; white-space: pre-line; }
    .closing { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); color: var(--muted); }

    /* Lightbox */
    .lb {
      position: fixed; inset: 0; z-index: 1000;
      display: flex; align-items: center; justify-content: center;
      background: rgba(0, 0, 0, 0.9);
      padding: 3.5rem 1rem 4.5rem;
    }
    .lb[hidden] { display: none; }
    .lb-stage {
      margin: 0; display: flex; flex-direction: column; align-items: center;
      gap: 0.75rem; width: min(1100px, 94vw); max-width: 94vw; height: 100%;
      background: none; border: none;
    }
    /* Fills the space the caption leaves, and can shrink so nothing clips. */
    .lb-imgwrap {
      flex: 1 1 auto; min-height: 0; width: 100%;
      display: flex; align-items: center; justify-content: center;
    }
    .lb-img {
      max-width: 100%; max-height: 100%;
      width: auto; height: auto; object-fit: contain;
      border-radius: 4px; background: #111;
    }
    .lb-caption {
      flex: 0 0 auto;
      color: #eee; font-size: 0.9rem; text-align: center; white-space: pre-line;
      max-width: 100%; max-height: 32vh; overflow-y: auto; padding: 0;
    }
    .lb-caption:empty { display: none; }
    .lb-btn {
      position: absolute; background: rgba(0, 0, 0, 0.4); color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.25); border-radius: 50%;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      line-height: 1; padding: 0; transition: background 0.15s ease;
    }
    .lb-btn:hover { background: rgba(255, 255, 255, 0.2); }
    .lb-close { top: 1rem; right: 1rem; width: 2.6rem; height: 2.6rem; font-size: 1.6rem; }
    .lb-prev, .lb-next { top: 50%; transform: translateY(-50%); width: 3rem; height: 3rem; font-size: 2rem; }
    .lb-prev { left: 1rem; }
    .lb-next { right: 1rem; }
    .lb-counter {
      position: absolute; bottom: 1.25rem; left: 50%; transform: translateX(-50%);
      color: #cfcfcf; font-size: 0.85rem; letter-spacing: 0.03em;
    }
    @media (max-width: 560px) {
      .lb-prev { left: 0.35rem; } .lb-next { right: 0.35rem; }
      .lb-btn { background: rgba(0, 0, 0, 0.55); }
      .lb-img { max-height: 74vh; }
    }
  </style>

  <script>
    const links = Array.from(document.querySelectorAll('a.ph-link'));
    const lb = document.getElementById('lightbox');
    if (lb && links.length) {
      const img = lb.querySelector('.lb-img');
      const cap = lb.querySelector('.lb-caption');
      const counter = lb.querySelector('.lb-counter');
      let idx = 0;

      const preload = (i) => {
        const a = links[i];
        if (a) new Image().src = a.getAttribute('href');
      };

      const show = (i) => {
        idx = (i + links.length) % links.length;
        const a = links[idx];
        img.src = a.getAttribute('href');
        const c = a.dataset.caption || '';
        img.alt = c || 'Photo ' + (idx + 1);
        cap.textContent = c;
        counter.textContent = idx + 1 + ' / ' + links.length;
        preload(idx + 1);
        preload(idx - 1);
      };

      const open = (i) => {
        show(i);
        lb.hidden = false;
        document.body.style.overflow = 'hidden';
      };
      const close = () => {
        lb.hidden = true;
        document.body.style.overflow = '';
        img.src = '';
      };

      links.forEach((a, i) =>
        a.addEventListener('click', (e) => {
          e.preventDefault();
          open(i);
        }),
      );
      lb.querySelector('.lb-next').addEventListener('click', (e) => { e.stopPropagation(); show(idx + 1); });
      lb.querySelector('.lb-prev').addEventListener('click', (e) => { e.stopPropagation(); show(idx - 1); });
      lb.querySelector('.lb-close').addEventListener('click', close);
      lb.addEventListener('click', (e) => { if (e.target === lb || e.target.classList.contains('lb-stage')) close(); });

      document.addEventListener('keydown', (e) => {
        if (lb.hidden) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowRight') show(idx + 1);
        else if (e.key === 'ArrowLeft') show(idx - 1);
      });

      // Touch swipe on the image.
      let sx = 0;
      lb.addEventListener('touchstart', (e) => { sx = e.changedTouches[0].clientX; }, { passive: true });
      lb.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - sx;
        if (Math.abs(dx) > 45) show(idx + (dx < 0 ? 1 : -1));
      }, { passive: true });
    }
  </script>
</BaseLayout>
