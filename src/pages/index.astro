---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Latest 3 non-draft news items: pinned first, then newest by date.
const news = (await getCollection('news', ({ data }) => !data.draft))
  .sort(
    (a, b) =>
      Number(b.data.pinned) - Number(a.data.pinned) ||
      b.data.date.valueOf() - a.data.date.valueOf(),
  )
  .slice(0, 3);

// Frontmatter dates are parsed as UTC midnight; format in UTC too so a date
// written as 2026-07-15 doesn't render as the 14th in a behind-UTC timezone.
const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<BaseLayout title="Moratuwa 77'-82' — Home">
  <section class="hero">
    <h1>Moratuwa 77'-82'</h1>
    <p class="tagline">Reunion photos and news for our batch.</p>
    <div class="cta">
      <a class="btn" href="/gallery/">Browse the gallery</a>
      <a class="btn ghost" href="/members/">See the members</a>
    </div>
  </section>

  <section>
    <h2>Latest news</h2>
    <ul class="news-list">
      {news.map((item) => (
        <li>
          <a href={item.data.link ?? `/news/${item.slug}/`}>
            <span class="date">{fmt(item.data.date)}</span>
            <span class="title">{item.data.title}</span>
          </a>
          {item.data.summary && <p class="summary">{item.data.summary}</p>}
        </li>
      ))}
    </ul>
  </section>

  <style>
    .hero {
      text-align: center;
      padding: 2.5rem 0 1.5rem;
    }
    .hero h1 { font-size: clamp(2.2rem, 6vw, 3.5rem); margin: 0 0 0.25rem; }
    .tagline { color: var(--muted); font-size: 1.15rem; margin: 0 0 1.5rem; }
    .cta { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-block; padding: 0.6rem 1.2rem; border-radius: 8px;
      background: var(--accent); color: #fff; text-decoration: none; font-weight: 600;
    }
    .btn.ghost { background: transparent; color: var(--accent); border: 1px solid var(--accent); }

    h2 { border-bottom: 1px solid var(--border); padding-bottom: 0.4rem; }
    .news-list { list-style: none; padding: 0; margin: 0; }
    .news-list li { padding: 1rem 0; border-bottom: 1px solid var(--border); }
    .news-list a { text-decoration: none; display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: baseline; }
    .news-list .date { color: var(--muted); font-size: 0.85rem; min-width: 8rem; }
    .news-list .title { color: var(--fg); font-weight: 600; font-size: 1.1rem; }
    .news-list .summary { color: var(--muted); margin: 0.35rem 0 0; }
  </style>
</BaseLayout>
