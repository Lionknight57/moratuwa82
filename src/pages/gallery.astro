---
import BaseLayout from '../layouts/BaseLayout.astro';
import CldImage from '../components/CldImage.astro';
import { photos } from '../data/gallery';
import { albums, photoCount } from '../data/albums';
---

<BaseLayout title="Gallery — Moratuwa 77'-82'" description="Batch photos through the years.">
  <h1>Gallery</h1>
  <p class="intro">Photos from our years together and the reunions since. Have more? Send them to the committee.</p>

  <h2>Albums</h2>
  <div class="grid">
    {albums.map((album) => (
      <a class="album-card" href={`/gallery/${album.slug}/`}>
        <CldImage publicId={album.cover} alt={`${album.title} — album cover`} width={600} height={450} />
        <div class="album-meta">
          <span class="album-title">{album.title}</span>
          <span class="album-summary">{album.summary}</span>
          <span class="album-count">{photoCount(album)} {photoCount(album) === 1 ? 'photo' : 'photos'}</span>
        </div>
      </a>
    ))}
  </div>

  <h2>Recent</h2>
  <div class="grid">
    {photos.map((photo) => (
      <figure>
        <CldImage publicId={photo.publicId} alt={photo.caption} width={600} height={450} />
        <figcaption>{photo.caption}</figcaption>
      </figure>
    ))}
  </div>

  <style>
    h1 { border-bottom: 1px solid var(--border); padding-bottom: 0.4rem; }
    .intro { color: var(--muted); }
    h2 { font-size: 1.05rem; margin: 2.5rem 0 0.75rem; }
    .album-card {
      display: block; text-decoration: none; color: inherit;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; overflow: hidden;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .album-card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .album-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
    .album-meta { display: flex; flex-direction: column; gap: 0.15rem; padding: 0.6rem 0.75rem; }
    .album-title { font-weight: 600; }
    .album-summary { color: var(--muted); font-size: 0.85rem; }
    .album-count { color: var(--muted); font-size: 0.8rem; }
    @media (prefers-reduced-motion: reduce) {
      .album-card { transition: none; }
      .album-card:hover { transform: none; }
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }
    figure { margin: 0; background: var(--card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    figure img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
    figcaption { padding: 0.6rem 0.75rem; color: var(--muted); font-size: 0.9rem; }
  </style>
</BaseLayout>
