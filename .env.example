# Copy this file to ".env" and fill in your Cloudinary details there.
# Find them in the Cloudinary console (Settings -> API Keys).
#
# Put real values in ".env", which is gitignored. This file is a committed
# template — never put the API secret here.

# The cloud name is baked into public image URLs. The PUBLIC_ prefix is required
# so Astro exposes it to the browser.
PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Only needed to run the upload script (npm run upload:historical).
# NOT prefixed with PUBLIC_, so these never reach the browser.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Without a .env the site falls back to Cloudinary's public "demo" cloud so it
# still renders sample images during development.
